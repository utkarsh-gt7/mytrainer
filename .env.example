# =============================================================================
# Local development environment — copy to .env and fill in your own values.
# =============================================================================
# Vite loads this order at startup: .env.local > .env.[mode].local > .env > .env.[mode]
#
# The committed .env.production already contains the Firebase Web config for
# production builds (those values are public by design — see that file's
# header comment). This template is just for local dev.
# =============================================================================

# Firebase Web Config — required (app runs in cloud-only mode)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Gemini API Key — optional, enables AI food image analysis.
# Treat this as a real secret. Never commit. In Netlify, add it under
# Environment variables with scope "Builds" + "Production".
VITE_GEMINI_API_KEY=
